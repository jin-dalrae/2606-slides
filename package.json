{
  "name": "2606-slides",
  "version": "1.0.0",
  "private": true,
  "description": "Rae Jin Slides — static presentation library under public/, Worker in src/. Client is ES modules in public/js/.",
  "scripts": {
    "dev": "npx wrangler dev",
    "deploy": "npx wrangler deploy",
    "seed": "node seed.js --local",
    "seed:remote": "node seed.js --remote",
    "build:gtr": "esbuild public/gtr/app.jsx --bundle --format=iife --outfile=public/gtr/app.js --loader:.jsx=jsx --jsx-factory=React.createElement --jsx-fragment=React.Fragment",
    "watch:gtr": "esbuild public/gtr/app.jsx --bundle --format=iife --outfile=public/gtr/app.js --loader:.jsx=jsx --jsx-factory=React.createElement --jsx-fragment=React.Fragment --watch",
    "build:cosmos": "esbuild public/cosmos/app.jsx --bundle --format=iife --outfile=public/cosmos/app.js --loader:.jsx=jsx --jsx-factory=React.createElement --jsx-fragment=React.Fragment"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "d3-force": "^3.0.0"
  }
}
